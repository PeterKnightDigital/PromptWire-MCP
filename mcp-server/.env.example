# PW-MCP Environment Configuration

# Path to your ProcessWire installation root (REQUIRED)
PW_PATH=/path/to/your/processwire-site

# Path to PHP binary (optional, defaults to 'php')
# Uncomment if using MAMP, XAMPP, or non-standard PHP location
# PHP_PATH=/Applications/MAMP/bin/php/php8.3.28/bin/php

# Path to the PW-MCP CLI script (optional)
# Only needed if module is NOT installed in standard location: /site/modules/PwMcp/
# PW_MCP_CLI_PATH=/custom/path/to/PwMcp/bin/pw-mcp.php
